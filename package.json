{
  "name": "mediapolotx-desktop",
  "version": "0.1.0",
  "description": "Desktop client for MediapolotX local/NAS media management and batch processing.",
  "main": "src/main/main.js",
  "author": "object-tao",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder --config electron.config.js --dir",
    "dist": "npm run build && electron-builder --config electron.config.js",
    "lint": "eslint .",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "axios": "^1.7.9",
    "chokidar": "^4.0.3",
    "electron-log": "^5.2.4",
    "exiftool-vendored": "^36.0.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "sql.js": "^1.12.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
